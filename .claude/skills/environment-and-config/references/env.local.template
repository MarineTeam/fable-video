# .env.local template for Marine Video Portal
#
# Copy this file to the repo root as `.env.local` (gitignored — never commit it).
# Fill in real values for whichever services you have; leave the rest blank/placeholder.
# See ../SKILL.md for the full inventory, degraded-mode matrix, and setup runbook.
#
#   cp .claude/skills/environment-and-config/references/env.local.template .env.local
#
# Next.js loads .env.local automatically for `npm run dev` / `npm run build` / `npm start`.
# There is no .env.example in this repo (a known gap) — this file is the substitute.

# ---------------------------------------------------------------------------
# AUTH0 (required — read by @auth0/nextjs-auth0's Auth0Client() in lib/auth0.js)
# Without ALL of these, every page throws at request time (and `next build`
# fails during page-data collection). No degraded mode: auth is all-or-nothing.
# ---------------------------------------------------------------------------
AUTH0_SECRET=                  # openssl rand -hex 32
AUTH0_DOMAIN=                  # your-tenant.us.auth0.com  (NO https://, NO scheme)
AUTH0_CLIENT_ID=               # from Auth0 application settings
AUTH0_CLIENT_SECRET=           # from Auth0 application settings
APP_BASE_URL=http://localhost:3000   # exact site URL, no trailing slash

# ---------------------------------------------------------------------------
# ADMIN ACCESS (required for anyone to reach /admin or bypass approval)
# ---------------------------------------------------------------------------
ADMIN_EMAILS=you@example.com   # comma-separated, case-insensitive, whitespace trimmed

# ---------------------------------------------------------------------------
# BUNNY.NET STREAM (required for video playback/upload/listing)
# ---------------------------------------------------------------------------
BUNNY_LIBRARY_ID=              # Stream library ID (numeric, as a string)
BUNNY_API_KEY=                 # Stream library API key
BUNNY_TOKEN_AUTH_KEY=          # Embed View Token Authentication key (Security tab)
                                # also the default source for signed thumbnail tokens

# Optional bunny extras
BUNNY_CDN_HOSTNAME=            # pull-zone host, e.g. vz-xxxx-xxx.b-cdn.net
                                # UNSET = homepage falls back to a title list, no thumbnails
BUNNY_CDN_TOKEN_KEY=           # only if the pull zone's token key differs from
                                # BUNNY_TOKEN_AUTH_KEY (falls back to it if unset)

# ---------------------------------------------------------------------------
# REDIS / UPSTASH (required for admin panel, approval, shares)
# Prefer the exact names below. Vercel's Storage tab may inject prefixed
# names instead (e.g. fablevideo_KV_REST_API_URL) when multiple stores are
# connected — lib/redis.js resolves those by suffix automatically. Locally,
# just use the exact names.
# ---------------------------------------------------------------------------
KV_REST_API_URL=               # https://xxxx.upstash.io
KV_REST_API_TOKEN=
# Alternates (used only if the KV_REST_API_* names above are absent):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# RESEND EMAIL (optional — share links can always be copied manually instead)
# ---------------------------------------------------------------------------
RESEND_API_KEY=                # re_...
EMAIL_FROM=                    # Marine Video Portal <videos@yourdomain.com>
                                # domain must be verified in Resend
EMAIL_REPLY_TO=                # optional
SITE_NAME=                     # portal name used inside emails (default: "Marine Video Portal")

# ---------------------------------------------------------------------------
# BROWSER-EXPOSED CONFIG (NEXT_PUBLIC_ = bundled into client JS, world-readable)
# NEVER put a secret in a NEXT_PUBLIC_ variable.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=         # portal name shown in header/title (default: "Marine Video Portal")

# ---------------------------------------------------------------------------
# WEB PUSH (optional — inert if unset; the "Notify me" button hides and the
# admin broadcast card shows a setup hint). Generate the pair with:
#   npx web-push generate-vapid-keys
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # VAPID public key — browser-safe (inlined into client JS)
VAPID_PRIVATE_KEY=             # VAPID private key — SECRET, server only, never NEXT_PUBLIC_
VAPID_SUBJECT=                 # optional mailto:/https: contact (default: APP_BASE_URL)

# ---------------------------------------------------------------------------
# GEO-LOCATION WHITELIST (optional — inert if unset; only takes effect on
# Vercel, since it reads Vercel's request-geolocation header). Set via env
# var rather than the admin panel so an admin can always fix their own
# access by editing Vercel and redeploying, even if the site is currently
# blocking them.
# ---------------------------------------------------------------------------
GEO_WHITELIST=                 # comma-separated ISO 3166-1 alpha-2 codes, e.g. US,CA
                                # restricts the WHOLE site (incl. login) once the
                                # Settings-tab geoEnabled toggle is on
ADMIN_GEO_WHITELIST=           # same format — bypass list, only active once the
                                # Settings-tab adminGeoEnabled toggle is on
ADMIN_GEO_BYPASS_EMAILS=       # comma-separated admin emails — bypasses geo checks
                                # entirely, NO toggle, applies as soon as it's set.
                                # Arm before traveling; changes need a redeploy.

# ---------------------------------------------------------------------------
# SENTRY (optional — inert if unset, no error capture)
# ---------------------------------------------------------------------------
SENTRY_DSN=                    # server-side error capture
NEXT_PUBLIC_SENTRY_DSN=        # client-side error capture (safe to expose — DSNs are not secret)
SENTRY_ORG=                    # build-time source-map upload only
SENTRY_PROJECT=                # build-time source-map upload only
SENTRY_AUTH_TOKEN=             # build-time source-map upload only — treat as a secret,
                                # do NOT prefix NEXT_PUBLIC_, do NOT commit

# ---------------------------------------------------------------------------
# CI is NOT something you set locally — next.config.js reads process.env.CI
# to decide whether the Sentry webpack plugin logs verbosely. GitHub Actions
# sets it automatically. Leave unset for local dev.
# ---------------------------------------------------------------------------
# CI=
